{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx memory/scripts/memory-runner.ts session-start",
            "statusMessage": "Loading memory context and adaptive learning rules",
            "timeoutSec": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/privacy-hook.sh",
            "statusMessage": "Privacy check",
            "timeoutSec": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsx memory/scripts/memory-runner.ts flush",
            "statusMessage": "Flushing pending memories",
            "timeoutSec": 30
          }
        ]
      }
    ]
  }
}
